EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_m7deqa--hK3BofZbiTzcuQ_6Q1wrzyn
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=
# Expo SDK 56+ made its native expo/fetch (OkHttp on Android) the global
# fetch. It has known cancellation bugs (spurious "Fetch request has been
# canceled" errors, e.g. expo/expo#34772) that break Supabase auth calls.
# This restores React Native's built-in fetch as the global implementation.
EXPO_PUBLIC_USE_RN_FETCH=1
