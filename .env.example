# ─────────────────────────────────────────────────────────────
# AfriLove World — variables d'environnement
# Copiez ce fichier en `.env` puis renseignez les valeurs.
# Le préfixe EXPO_PUBLIC_ = exposé au bundle client.
# ─────────────────────────────────────────────────────────────

# Supabase (obligatoire) — des valeurs par défaut existent déjà dans le code,
# mais renseignez-les explicitement pour vos propres environnements.
EXPO_PUBLIC_SUPABASE_URL=https://xhpwmondzarbnzciruis.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth (optionnel) — active le bouton "Continuer avec Google".
# Créez un OAuth Web Client ID dans Google Cloud Console.
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=

# Sentry (optionnel) — crash reporting. Laissé vide, l'app fonctionne
# exactement pareil (le monitoring reste inerte).
EXPO_PUBLIC_SENTRY_DSN=
