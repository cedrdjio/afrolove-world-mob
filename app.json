{
  "expo": {
    "name": "AfriLove World",
    "slug": "afrolove-world-mob",
    "scheme": "afrolove",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e1f490c0-a466-49d8-9cbf-5b1bd58c051d",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.afroloveworld.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AfriLove World utilise votre position pour vous proposer des rencontres près de chez vous. Elle n'est jamais montrée aux autres membres.",
        "NSCameraUsageDescription": "La caméra sert à prendre vos photos de profil et à vérifier votre identité (badge vérifié).",
        "NSPhotoLibraryUsageDescription": "Vos photos servent à composer votre profil AfriLove World."
      }
    },
    "android": {
      "package": "com.afroloveworld.app",
      "adaptiveIcon": {
        "backgroundColor": "#221937",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-location",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#221937",
          "image": "./assets/splash-icon.png",
          "imageWidth": 140
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-foreground.png",
          "color": "#9B7EDE"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AfriLove World a besoin d'accéder à vos photos pour créer votre profil.",
          "cameraPermission": "La caméra sert à prendre vos photos de profil et à vérifier votre identité."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "reactNativeArchitectures": [
              "arm64-v8a"
            ],
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1f490c0-a466-49d8-9cbf-5b1bd58c051d"
      }
    },
    "owner": "cedjio"
  }
}
